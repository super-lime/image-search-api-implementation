{
  "family": "image-search-api",
  "taskRoleArn": "arn:aws:iam::542265692887:role/ecsTaskExecutionRole",
  "executionRoleArn": "arn:aws:iam::542265692887:role/ecsTaskExecutionRole",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1 vCPU",
  "memory": "3GB",
  "containerDefinitions": [
    {
      "name": "image-search-api",
      "image": "IMAGE_PLACEHOLDER",
      "portMappings": [
        { "containerPort": 3000, "protocol": "tcp" }
      ],
      "environment": [
        { "name": "PORT", "value": "3000" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/image-search-api",
          "awslogs-region": "ap-southeast-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}